# VaidyaAI Backend Environment Variables
# Copy this file to .env and fill in your actual keys

# Groq API Key (Required) — Get free at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Gemini API Key (Optional — for image analysis) — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Sarvam AI Key (Optional — for regional TTS/STT) — https://www.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here

# Environment
ENVIRONMENT=development
